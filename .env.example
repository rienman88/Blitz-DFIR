# LLM provider configuration. Never commit real values in .env.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120

# Windows-hosted Ollama from a SIFT VMware guest example:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://192.168.88.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2:1b
# LLM_TIMEOUT_SECONDS=600
